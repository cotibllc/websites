<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#071629">

<title>{{ title or site.seo.title }}</title>
<meta name="description" content="{{ description or site.seo.description }}">

<!-- Canonical -->
<link rel="canonical" href="{{ site.siteUrl }}{{ canonical or '' }}">

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:title" content="{{ title or site.seo.title }}">
<meta property="og:description" content="{{ description or site.seo.description }}">
<meta property="og:image" content="{{ site.siteUrl }}{{ site.seo.ogImage }}">
<meta property="og:url" content="{{ site.siteUrl }}">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="{{ site.seo.twitterHandle }}">
<meta name="twitter:title" content="{{ title or site.seo.title }}">
<meta name="twitter:description" content="{{ description or site.seo.description }}">
<meta name="twitter:image" content="{{ site.siteUrl }}{{ site.seo.ogImage }}">

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/images/logo/ee-favicon.svg">

<!-- Google Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Styles -->
<link rel="stylesheet" href="/css/main.css">

<!-- Structured Data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Earned Escape",
  "description": "Certified travel advisory specializing in Royal Caribbean, Disney, and Universal Resorts.",
  "url": "https://earnedescape.agency",
  "sameAs": [
    "https://instagram.com/earned_escape",
    "https://pinterest.com/earned_escape"
  ],
  "founder": {
    "@type": "Person",
    "name": "Chuck Betancourt"
  }
}
</script>
