<section class="hero" id="hero">
  <canvas class="hero__starfield" id="starfield-canvas" aria-hidden="true"></canvas>

  <div class="hero__horizon-glow" aria-hidden="true"></div>
  <div class="hero__horizon-line" aria-hidden="true"></div>

  <img
    src="/images/logo/ee-horizon-mark.svg"
    alt=""
    class="hero__watermark"
    aria-hidden="true"
    width="600"
    height="600"
  >

  <div class="hero__content">
    <p class="hero__eyebrow animate-fade-up" style="animation-delay:0.2s">
      Certified Travel Advisory &middot; earnedescape.agency
    </p>

    <h1 class="hero__headline animate-fade-up" style="animation-delay:0.4s">
      The trips<br>
      you've <em>earned</em><br>
      <span class="hero__headline--outline">deserve an expert.</span>
    </h1>

    <p class="hero__sub animate-fade-up" style="animation-delay:0.6s">
      Royal Caribbean. Disney. Universal. Disney Cruise Line.<br>
      Expert guidance, personal service, and zero added cost to you.
    </p>

    <div class="hero__ctas animate-fade-up" style="animation-delay:0.8s">
      <a href="{{ site.links.consultation }}" class="btn btn--gold" target="_blank" rel="noopener noreferrer">
        Book Free Consultation
      </a>
      <a href="#guides" class="btn btn--outline">
        Download Free Guides
      </a>
    </div>
  </div>

  <div class="hero__scroll animate-fade-up" style="animation-delay:1.2s" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-label">Explore</span>
  </div>

</section>
