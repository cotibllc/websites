<section class="destinations" id="destinations">
  <div class="destinations__inner">

    <div class="destinations__header">
      <p class="section-eyebrow">Destinations</p>
      <h2 class="destinations__headline">
        Where will you <em>escape</em> to?
      </h2>

      <div class="dest-tabs" role="tablist">
        <button
          class="dest-tab dest-tab--active"
          data-panel="cruise"
          role="tab"
          aria-selected="true"
          aria-controls="panel-cruise"
          id="tab-cruise"
        >
          <span>&#x1F6A2;</span> Cruise Voyages
        </button>
        <button
          class="dest-tab"
          data-panel="parks"
          role="tab"
          aria-selected="false"
          aria-controls="panel-parks"
          id="tab-parks"
        >
          <span>&#x1F3A2;</span> Theme Parks
        </button>
      </div>
    </div>

    <!-- Cruise Panel -->
    <div class="dest-panel dest-panel--active" id="panel-cruise" role="tabpanel" aria-labelledby="tab-cruise">
      <div class="dest-grid">

        <article class="dest-card dest-card--rc">
          <div class="dest-card__bg"></div>
          <div class="dest-card__overlay"></div>
          <span class="dest-card__domain">earnedescape.voyage</span>
          <div class="dest-card__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <circle cx="20" cy="20" r="18" stroke="#C9A84C" stroke-width="1.5" fill="none" opacity="0.6"/>
              <path d="M8 24 Q14 18 20 22 Q26 26 32 20" stroke="#C9A84C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <path d="M16 22 L16 14 L24 18 Z" fill="#C9A84C" opacity="0.7"/>
            </svg>
          </div>
          <div class="dest-card__content">
            <p class="dest-card__eyebrow">Royal Caribbean</p>
            <h3 class="dest-card__title">The World's Greatest Cruise Line</h3>
            <p class="dest-card__desc">From Caribbean islands to Alaskan glaciers, Royal Caribbean offers a scale and variety that has to be experienced. Let me match you to the right ship and itinerary for your family.</p>
            <a href="{{ site.links.consultation }}" class="dest-card__link" target="_blank" rel="noopener noreferrer">
              Plan Your Voyage &rarr;
            </a>
          </div>
        </article>

        <article class="dest-card dest-card--dcl">
          <div class="dest-card__bg"></div>
          <div class="dest-card__overlay"></div>
          <span class="dest-card__domain">earnedescape.voyage</span>
          <div class="dest-card__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <circle cx="20" cy="20" r="18" stroke="#C9A84C" stroke-width="1.5" fill="none" opacity="0.6"/>
              <path d="M12 26 Q16 20 20 22 Q24 24 28 18" stroke="#C9A84C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <circle cx="20" cy="16" r="3" fill="#C9A84C" opacity="0.7"/>
            </svg>
          </div>
          <div class="dest-card__content">
            <p class="dest-card__eyebrow">Disney Cruise Line</p>
            <h3 class="dest-card__title">Magic on the Open Ocean</h3>
            <p class="dest-card__desc">Disney storytelling meets world-class cruising. Perfect for families and multigenerational groups — the service, the characters, and the attention to detail are unlike anything else at sea.</p>
            <a href="{{ site.links.consultation }}" class="dest-card__link" target="_blank" rel="noopener noreferrer">
              Plan Your Voyage &rarr;
            </a>
          </div>
        </article>

      </div>
    </div>

    <!-- Parks Panel -->
    <div class="dest-panel" id="panel-parks" role="tabpanel" aria-labelledby="tab-parks" hidden>
      <div class="dest-grid">

        <article class="dest-card dest-card--wdw">
          <div class="dest-card__bg"></div>
          <div class="dest-card__overlay"></div>
          <span class="dest-card__domain">earnedescape.vacations</span>
          <div class="dest-card__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <circle cx="20" cy="20" r="18" stroke="#C9A84C" stroke-width="1.5" fill="none" opacity="0.6"/>
              <path d="M20 10 L22 16 L28 16 L23 20 L25 26 L20 22 L15 26 L17 20 L12 16 L18 16 Z" fill="#C9A84C" opacity="0.7"/>
            </svg>
          </div>
          <div class="dest-card__content">
            <p class="dest-card__eyebrow">Walt Disney World</p>
            <h3 class="dest-card__title">The Most Magical Place on Earth</h3>
            <p class="dest-card__desc">Four parks, two water parks, Disney Springs, and a resort strategy that can make or break your trip. Let me handle the planning so you can be fully present for every moment of it.</p>
            <a href="{{ site.links.consultation }}" class="dest-card__link" target="_blank" rel="noopener noreferrer">
              Plan Your Visit &rarr;
            </a>
          </div>
        </article>

        <article class="dest-card dest-card--uni">
          <div class="dest-card__bg"></div>
          <div class="dest-card__overlay"></div>
          <span class="dest-card__domain">earnedescape.vacations</span>
          <div class="dest-card__icon" aria-hidden="true">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="24" height="24">
              <circle cx="20" cy="20" r="18" stroke="#C9A84C" stroke-width="1.5" fill="none" opacity="0.6"/>
              <path d="M14 28 L14 18 Q14 12 20 12 Q26 12 26 18 L26 28" stroke="#C9A84C" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              <line x1="11" y1="28" x2="29" y2="28" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="dest-card__content">
            <p class="dest-card__eyebrow">Universal Resorts</p>
            <h3 class="dest-card__title">Epic Universe Awaits</h3>
            <p class="dest-card__desc">Epic Universe, Islands of Adventure, Universal Studios — the thrill-seeker's destination just got significantly bigger. I'll build a plan that captures it all without the overwhelm.</p>
            <a href="{{ site.links.universalLink }}" class="dest-card__link" target="_blank" rel="noopener noreferrer">
              Explore Epic Universe &rarr;
            </a>
          </div>
        </article>

      </div>
    </div>

  </div>
</section>
